---
export interface Props {
    gearName: string;
}

const { gearName } = Astro.props;

// Convert "Boss OD-3" to "boss-od-3" for the URL
const formattedUrl = gearName.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
---

<a 
    href={`${import.meta.env.BASE_URL}/gear/${formattedUrl}`} 
    class="inline-block bg-[#111] text-silver px-3 py-1 m-1 font-mono text-xs uppercase tracking-widest border-t border-l border-white/20 border-b-2 border-r-2 border-black shadow-[2px_2px_4px_rgba(0,0,0,0.8)] transition-all duration-200 hover:bg-mustard hover:text-black hover:border-mustardDark hover:translate-y-[1px] hover:shadow-[1px_1px_2px_rgba(0,0,0,0.8)]"
>
    {gearName}
</a>
