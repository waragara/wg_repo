---
import Layout from '../../layouts/Layout.astro';
import SetupCard from '../../components/SetupCard.astro';

export async function getStaticPaths() {
    const allSetups = Object.values(import.meta.glob('../../content/setups/*.md', { eager: true }));
    
    // Create a Set to hold unique gear names
    const uniqueGear = new Set<string>();
    
    allSetups.forEach((setup: any) => {
        if (setup.frontmatter && setup.frontmatter.signalChain) {
            const rawChain = setup.frontmatter.signalChain.replace(/[🎸🔊]/g, '').trim();
            const items = rawChain.split('->').map((item: string) => item.trim()).filter((i: string) => i.length > 0);
            items.forEach((item: string) => uniqueGear.add(item));
        }
    });

    return Array.from(uniqueGear).map((gearName) => {
        const formattedUrl = gearName.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
        
        // Find all setups that use this gear
        const filteredSetups = allSetups.filter((setup: any) => {
             const rawChain = setup.frontmatter.signalChain.replace(/[🎸🔊]/g, '').trim();
             const items = rawChain.split('->').map((item: string) => item.trim());
             return items.includes(gearName);
        });

        return {
            params: { gear: formattedUrl },
            props: { 
                gearName, 
                setups: filteredSetups 
            }
        };
    });
}

const { gearName, setups } = Astro.props;
---

<Layout title={`Setups using: ${gearName}`}>
    <div class="mb-8">
        <a href={`${import.meta.env.BASE_URL}/`} class="inline-block bg-mustard text-tolexDark py-2 px-6 rounded-md text-sm font-bold no-underline transition-all duration-200 hover:bg-mustardDark hover:shadow-[0_0_15px_rgba(234,179,8,0.5)] border-b-4 border-mustardDark active:translate-y-1 active:border-b-0 uppercase tracking-wide">
            ⬅ Voltar para Setups
        </a>
    </div>

    <!-- Header Panel -->
    <div class="relative bg-brushed-metal p-6 md:p-10 border-4 border-[#111] shadow-[0_10px_30px_rgba(0,0,0,0.9)] rounded mb-12 flex flex-col items-center justify-center min-h-[200px]">
        <!-- Screws -->
        <div class="absolute top-3 left-3 w-3 h-3 rounded-full bg-black/60 shadow-inner border border-black/80"></div>
        <div class="absolute top-3 right-3 w-3 h-3 rounded-full bg-black/60 shadow-inner border border-black/80"></div>
        <div class="absolute bottom-3 left-3 w-3 h-3 rounded-full bg-black/60 shadow-inner border border-black/80"></div>
        <div class="absolute bottom-3 right-3 w-3 h-3 rounded-full bg-black/60 shadow-inner border border-black/80"></div>
        
        <h2 class="text-xl md:text-2xl font-bold font-mono text-[#333] uppercase tracking-widest mb-2">Setups using:</h2>
        <h1 class="text-4xl md:text-6xl font-black font-slab uppercase tracking-widest text-[#111] drop-shadow-md text-center m-0">
            {gearName}
        </h1>
        <div class="mt-4 bg-[#111] text-mustard px-4 py-1 rounded font-mono text-sm tracking-widest shadow-inner border border-black/50">
            Encontrados: {setups.length}
        </div>
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 xl:grid-cols-2 gap-8">
        {setups.map((setup: any) => (
            <SetupCard 
                title={setup.frontmatter.title}
                targetTone={setup.frontmatter.targetTone}
                signalChain={setup.frontmatter.signalChain}
                tabs={setup.frontmatter.tabs}
                equipment={setup.frontmatter.equipment}
            />
        ))}
    </div>
</Layout>
