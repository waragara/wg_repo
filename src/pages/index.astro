---
import Layout from '../layouts/Layout.astro';
import SetupCard from '../components/SetupCard.astro';
import GearBadge from '../components/GearBadge.astro';
import BandBadge from '../components/BandBadge.astro';
import { getCollection } from 'astro:content';

// Fetch all setups from the content collection
const setups = await getCollection('setups');

const extractBand = (title: string) => {
    if (!title) return '';
    return title
        .replace(/\(.*?\)/g, '') // Remove parenthesis like (Jangly)
        .replace(/\s+(I|II|III|IV|V|VI|VII|VIII|IX|X)$/i, '') // Remove roman numerals
        .trim();
};

// Extract unique gear and bands for the global filters
const uniqueGear = new Set<string>();
const uniqueBands = new Set<string>();

setups.forEach((setup: any) => {
    // Gear
    if (setup.data.guitar) uniqueGear.add(setup.data.guitar);
    if (setup.data.amp) uniqueGear.add(setup.data.amp);
    if (setup.data.pedals) {
        setup.data.pedals.forEach((pedal: string) => uniqueGear.add(pedal));
    }
    // Band
    if (setup.data.artist) {
        uniqueBands.add(setup.data.artist);
    }
});
const allGearTags = Array.from(uniqueGear).sort();
const allBandTags = Array.from(uniqueBands).sort();
---

<Layout title="Tussi RigCraft Labs">

    <!-- NAVEGAÇÃO PRINCIPAL -->
    <div class="bg-black/60 p-6 sm:p-8 rounded-xl shadow-[inset_0_2px_10px_rgba(0,0,0,0.8)] border border-black/50 mb-12 max-w-4xl mx-auto">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-center">
            <!-- Linha 1 -->
            <a href={`${import.meta.env.BASE_URL}/tank-g-presets`} class="w-full inline-block bg-accentOrange text-bgMain py-3 px-4 rounded text-lg font-bold no-underline transition-transform duration-200 hover:-translate-y-1 hover:bg-[#e68a00] hover:shadow-[0_5px_15px_rgba(234,179,8,0.4)]">
                🎛️ Lista Presets M-Vave TANK-G
            </a>
            <a href={`${import.meta.env.BASE_URL}/boss-katana-go-presets`} class="w-full inline-block bg-accentOrange text-bgMain py-3 px-4 rounded text-lg font-bold no-underline transition-transform duration-200 hover:-translate-y-1 hover:bg-[#e68a00] hover:shadow-[0_5px_15px_rgba(234,179,8,0.4)]">
                🎛️ Lista Presets Boss Katana GO
            </a>
            
            <!-- Linha 2 -->
            <a href={`${import.meta.env.BASE_URL}/admin/add-setup`} class="w-full inline-block bg-silver text-tolexDark py-3 px-4 rounded text-lg font-bold no-underline transition-transform duration-200 hover:-translate-y-1 hover:bg-white border-2 border-[#111] shadow-[0_4px_10px_rgba(0,0,0,0.5)]">
                ⚙️ Adicionar Setup (Admin)
            </a>
            <a href={`${import.meta.env.BASE_URL}/mural`} class="w-full inline-block bg-brushed-metal text-[#111] py-3 px-4 rounded text-lg font-bold no-underline transition-transform duration-200 hover:-translate-y-1 hover:bg-white border-2 border-black shadow-[0_4px_10px_rgba(0,0,0,0.5)]">
                📸 Hall of Fame
            </a>
        </div>
    </div>

    <!-- GLOBAL FILTERS -->
    <div class="bg-black/60 p-6 rounded-xl shadow-[inset_0_2px_10px_rgba(0,0,0,0.8)] border border-black/50 mb-12 max-w-4xl mx-auto flex flex-col gap-6">
        
        {allBandTags.length > 0 && (
            <div>
                <h3 class="text-[#e0e0e0] font-mono text-center font-bold uppercase mb-3 tracking-widest text-lg border-b-2 border-white/10 pb-2">🎵 Filtrar por Artista / Banda</h3>
                <div class="flex flex-wrap justify-center items-center gap-2">
                    {allBandTags.map((tag: string) => <BandBadge bandName={tag} />)}
                </div>
            </div>
        )}

        {allGearTags.length > 0 && (
            <div>
                <h3 class="text-mustard font-mono text-center font-bold uppercase mb-3 tracking-widest text-lg border-b-2 border-mustard/10 pb-2">🏷️ Filtrar por Equipamento</h3>
                <div class="flex flex-wrap justify-center items-center gap-1">
                    {allGearTags.map((tag: string) => <GearBadge gearName={tag} />)}
                </div>
            </div>
        )}
        
    </div>

    {setups.map(setup => (
        <SetupCard {...setup.data} />
    ))}
</Layout>
