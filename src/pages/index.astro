---
import Layout from '../layouts/Layout.astro';
import SetupCard from '../components/SetupCard.astro';
import GearBadge from '../components/GearBadge.astro';
import BandBadge from '../components/BandBadge.astro';
import { getCollection } from 'astro:content';

// Fetch all setups from the content collection
const setups = await getCollection('setups');

const extractBand = (title: string) => {
    if (!title) return '';
    return title
        .replace(/\(.*?\)/g, '') // Remove parenthesis like (Jangly)
        .replace(/\s+(I|II|III|IV|V|VI|VII|VIII|IX|X)$/i, '') // Remove roman numerals
        .trim();
};

// Extract unique gear and bands for the global filters
const uniqueGear = new Set<string>();
const uniqueBands = new Set<string>();

setups.forEach((setup: any) => {
    // Gear
    if (setup.data.guitar) uniqueGear.add(setup.data.guitar);
    if (setup.data.amp) uniqueGear.add(setup.data.amp);
    if (setup.data.pedals) {
        setup.data.pedals.forEach((pedal: string) => uniqueGear.add(pedal));
    }
    // Band
    if (setup.data.artist) {
        uniqueBands.add(setup.data.artist);
    }
});
const allGearTags = Array.from(uniqueGear).sort();
const allBandTags = Array.from(uniqueBands).sort();
---

<Layout title="Rock n' Roll Setup by Tussi Guitar">
    <!-- Galeria de Fotos -->
    <div class="flex justify-center items-center gap-8 mb-12 flex-wrap">
        
        {[
            { src: `${import.meta.env.BASE_URL}/pipito1.jpeg`, alt: 'No palco no Hard Rock Cafe', pos: 'object-center' },
            { src: `${import.meta.env.BASE_URL}/pipito2.jpg`, alt: 'Tocando guitarra Strato vermelha', pos: 'object-top' },
            { src: `${import.meta.env.BASE_URL}/pipito3.jpeg`, alt: 'Praticando com a Cort Les Paul', pos: 'object-center' }
        ].map(img => (
            <div class="relative bg-[#1a1a1a] p-3 rounded-xl shadow-[0_10px_20px_rgba(0,0,0,0.8)] border border-black/80 transition-transform duration-300 hover:-translate-y-2 hover:shadow-[0_15px_30px_rgba(234,179,8,0.2)] group cursor-pointer">
                <!-- Metal corner caps -->
                <div class="absolute top-[-2px] left-[-2px] w-4 h-4 bg-gradient-to-br from-silver to-metalPanelDark rounded-tl-xl border border-black/50 shadow-[inset_1px_1px_2px_rgba(255,255,255,0.8)]"></div>
                <div class="absolute top-[-2px] right-[-2px] w-4 h-4 bg-gradient-to-bl from-silver to-metalPanelDark rounded-tr-xl border border-black/50 shadow-[inset_-1px_1px_2px_rgba(255,255,255,0.8)]"></div>
                <div class="absolute bottom-[-2px] left-[-2px] w-4 h-4 bg-gradient-to-tr from-silver to-metalPanelDark rounded-bl-xl border border-black/50 shadow-[inset_1px_-1px_2px_rgba(255,255,255,0.8)]"></div>
                <div class="absolute bottom-[-2px] right-[-2px] w-4 h-4 bg-gradient-to-tl from-silver to-metalPanelDark rounded-br-xl border border-black/50 shadow-[inset_-1px_-1px_2px_rgba(255,255,255,0.8)]"></div>

                <!-- Inner Metallic Matting -->
                <div class="bg-brushed-metal p-2 rounded-lg shadow-[inset_0_5px_10px_rgba(0,0,0,0.5)] border border-black/40">
                    <!-- The actual photo -->
                    <img src={img.src} alt={img.alt} class={`w-[280px] h-[280px] object-cover ${img.pos} rounded border border-black/50 shadow-inner sepia-[0.3] contrast-125 group-hover:sepia-0 transition-all duration-500`}>
                </div>
            </div>
        ))}
        
    </div>

    <div class="flex flex-col sm:flex-row justify-center gap-4 mb-10 text-center flex-wrap">
        <a href={`${import.meta.env.BASE_URL}/tank-g-presets`} class="inline-block bg-accentOrange text-bgMain py-2.5 px-5 rounded text-lg font-bold no-underline transition-colors duration-200 hover:bg-[#e68a00]">
            🎛️ Ver Lista de Presets da M-Vave TANK-G
        </a>
        <a href={`${import.meta.env.BASE_URL}/boss-katana-go-presets`} class="inline-block bg-accentOrange text-bgMain py-2.5 px-5 rounded text-lg font-bold no-underline transition-colors duration-200 hover:bg-[#e68a00]">
            🎛️ Ver Lista de Presets Boss Katana:GO
        </a>
        <a href={`${import.meta.env.BASE_URL}/admin/add-setup`} class="inline-block bg-silver text-tolexDark py-2.5 px-5 rounded text-lg font-bold no-underline transition-colors duration-200 hover:bg-white border-2 border-[#111] shadow-[0_4px_10px_rgba(0,0,0,0.5)]">
            ⚙️ Adicionar Setup (Admin)
        </a>
    </div>

    <!-- GLOBAL FILTERS -->
    <div class="bg-black/60 p-6 rounded-xl shadow-[inset_0_2px_10px_rgba(0,0,0,0.8)] border border-black/50 mb-12 max-w-4xl mx-auto flex flex-col gap-6">
        
        {allBandTags.length > 0 && (
            <div>
                <h3 class="text-[#e0e0e0] font-mono text-center font-bold uppercase mb-3 tracking-widest text-lg border-b-2 border-white/10 pb-2">🎵 Filtrar por Artista / Banda</h3>
                <div class="flex flex-wrap justify-center items-center gap-2">
                    {allBandTags.map((tag: string) => <BandBadge bandName={tag} />)}
                </div>
            </div>
        )}

        {allGearTags.length > 0 && (
            <div>
                <h3 class="text-mustard font-mono text-center font-bold uppercase mb-3 tracking-widest text-lg border-b-2 border-mustard/10 pb-2">🏷️ Filtrar por Equipamento</h3>
                <div class="flex flex-wrap justify-center items-center gap-1">
                    {allGearTags.map((tag: string) => <GearBadge gearName={tag} />)}
                </div>
            </div>
        )}
        
    </div>

    {setups.map(setup => (
        <SetupCard {...setup.data} />
    ))}
</Layout>
